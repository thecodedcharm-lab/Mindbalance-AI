import numpy as np

class EmotionEnv:
    """
    Empathetic Workload & Burnout Environment (OpenEnv Compatible)
    """

    def __init__(self, level="medium"):
        self.level = level
        self.reset()

    def reset(self):
        config = {
            "easy": {"tasks": 3.0, "stress": 0.1},
            "medium": {"tasks": 6.0, "stress": 0.3},
            "hard": {"tasks": 10.0, "stress": 0.6}
        }

        curr = config.get(self.level, config["medium"])

        self.tasks_remaining = curr["tasks"]
        self.initial_tasks = curr["tasks"]

        self.stress = curr["stress"]
        self.energy = 0.8
        self.mood = 0.5

        self.steps_in_burnout = 0

        return self._get_obs()   # ✅ FIXED (no tuple)

    def _get_obs(self):
        return np.array([
            self.mood,
            self.energy,
            self.stress,
            self.tasks_remaining / 10.0
        ], dtype=np.float32)

    def step(self, action):
        reward = 0.0
        done = False
        info = {}

        # ACTION LOGIC
        if action == 0:  # REST
            self.energy = min(1.0, self.energy + 0.3)
            self.stress = max(0.0, self.stress - 0.05)
            reward += 0.1

        elif action == 1:  # LIGHT TASK
            if self.energy > 0.1:
                self.tasks_remaining -= 1
                self.energy -= 0.1
                self.stress += 0.1
                reward += 1.0
            else:
                reward -= 0.5

        elif action == 2:  # HEAVY TASK
            if self.energy > 0.4:
                self.tasks_remaining -= 2
                self.energy -= 0.3
                self.stress += 0.3
                reward += 2.5
            else:
                self.stress = min(1.0, self.stress + 0.4)
                reward -= 1.5

        elif action == 3:  # RELAXATION
            self.stress = max(0.0, self.stress - 0.4)
            self.mood = min(1.0, self.mood + 0.1)
            reward += 0.2

        elif action == 4:  # JOURNALING
            if self.stress > 0.5:
                self.stress -= 0.2
                self.mood = min(1.0, self.mood + 0.2)
                reward += 0.5

        # MOOD UPDATE
        if self.stress > 0.7 or self.energy < 0.2:
            self.mood = max(0.0, self.mood - 0.1)

        # BURNOUT SYSTEM
        if self.stress > 0.85:
            self.steps_in_burnout += 1
            reward -= 1.0
        else:
            self.steps_in_burnout = 0

        # TERMINATION CONDITIONS
        if self.steps_in_burnout >= 3:
            done = True
            reward -= 5.0
            info["reason"] = "Burnout"

        if self.tasks_remaining <= 0:
            done = True
            reward += 5.0
            info["reason"] = "Success"

        return self._get_obs(), float(reward), done, info   # ✅ FIXED


# 🔥 SMART AGENT
def smart_agent(env):
    if env.stress > 0.75:
        return 3  # Relax

    if env.energy < 0.3:
        return 0  # Rest

    if env.tasks_remaining > 3:
        return 2 if env.energy > 0.5 else 1

    return 1


# 📊 EVALUATION
def evaluate(env):
    task_score = (env.initial_tasks - env.tasks_remaining) / env.initial_tasks
    stress_penalty = env.stress * 0.3
    final = (0.7 * task_score) - stress_penalty
    return round(max(0.0, min(final, 1.0)), 2)


# 🚀 TEST RUN
if __name__ == "__main__":
    for level in ["easy", "medium", "hard"]:
        env = EmotionEnv(level)
        env.reset()

        total_reward = 0

        for _ in range(50):
            action = smart_agent(env)
            obs, reward, done, info = env.step(action)
            total_reward += reward

            if done:
                break

        print(f"\nLevel: {level}")
        print("Total Reward:", round(total_reward, 2))
        print("Performance:", evaluate(env))
        print("End Reason:", info.get("reason", "In Progress"))
