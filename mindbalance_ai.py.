import numpy as np

class Space:
    def __init__(self, n=None, shape=None):
        self.n = n
        self.shape = shape


class EmotionEnv:
    """
    Fully OpenEnv + HuggingFace Compatible Environment
    """

    def __init__(self, level="medium"):
        self.level = level

        # Required for OpenEnv
        self.action_space = Space(n=5)
        self.observation_space = Space(shape=(4,))

        self.reset()

    def reset(self):
        # 🔥 CRITICAL FIX (handles OpenEnv weird calls)
        self.level = getattr(self, "level", "medium")

        config = {
            "easy": {"tasks": 3.0, "stress": 0.1},
            "medium": {"tasks": 6.0, "stress": 0.3},
            "hard": {"tasks": 10.0, "stress": 0.6}
        }

        curr = config.get(self.level, config["medium"])

        self.tasks_remaining = curr["tasks"]
        self.initial_tasks = curr["tasks"]

        self.stress = curr["stress"]
        self.energy = 0.8
        self.mood = 0.5

        self.steps_in_burnout = 0

        return self._get_obs()

    def _get_obs(self):
        return np.array([
            self.mood,
            self.energy,
            self.stress,
            self.tasks_remaining / 10.0
        ], dtype=np.float32)

    def step(self, action):
        reward = 0.0
        done = False
        info = {}

        if action == 0:
            self.energy = min(1.0, self.energy + 0.3)
            self.stress = max(0.0, self.stress - 0.05)
            reward += 0.1

        elif action == 1:
            if self.energy > 0.1:
                self.tasks_remaining -= 1
                self.energy -= 0.1
                self.stress += 0.1
                reward += 1.0
            else:
                reward -= 0.5

        elif action == 2:
            if self.energy > 0.4:
                self.tasks_remaining -= 2
                self.energy -= 0.3
                self.stress += 0.3
                reward += 2.5
            else:
                self.stress = min(1.0, self.stress + 0.4)
                reward -= 1.5

        elif action == 3:
            self.stress = max(0.0, self.stress - 0.4)
            self.mood = min(1.0, self.mood + 0.1)
            reward += 0.2

        elif action == 4:
            if self.stress > 0.5:
                self.stress -= 0.2
                self.mood = min(1.0, self.mood + 0.2)
                reward += 0.5

        # Mood update
        if self.stress > 0.7 or self.energy < 0.2:
            self.mood = max(0.0, self.mood - 0.1)

        # Burnout system
        if self.stress > 0.85:
            self.steps_in_burnout += 1
            reward -= 1.0
        else:
            self.steps_in_burnout = 0

        # Termination
        if self.steps_in_burnout >= 3:
            done = True
            reward -= 5.0
            info["reason"] = "Burnout"

        if self.tasks_remaining <= 0:
            done = True
            reward += 5.0
            info["reason"] = "Success"

        return self._get_obs(), float(reward), done, info


# 🔥 Smart Agent
def smart_agent(env):
    if env.stress > 0.75:
        return 3
    if env.energy < 0.3:
        return 0
    if env.tasks_remaining > 3:
        return 2 if env.energy > 0.5 else 1
    return 1
